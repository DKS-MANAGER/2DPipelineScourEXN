// FIXES APPLIED:
// 1. top: symmetryPlane -> symmetry (see U for full explanation)
// 2. seabed: zeroGradient -> kqRWallFunction
//    kOmegaSST requires kqRWallFunction on wall patches. zeroGradient
//    produces unbounded k at the wall which triggers SIGFPE in the
//    omega dissipation term (k/omega) at step 2.
// 3. inlet: kept fixedValue to match turbulence intensity
// 4. Removed duplicate frontAndBack block.
// k = 1.5*(I*U)^2, I=0.05 (5%), U=0.4 m/s => k = 6e-4 m2/s2
FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0";
    object      k;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -2 0 0 0 0];

internalField   uniform 6e-4;

boundaryField
{
    inlet
    {
        type            fixedValue;
        value           uniform 6e-4;
    }
    outlet
    {
        type            zeroGradient;
    }
    top
    {
        type            symmetry;
    }
    seabed
    {
        type            kqRWallFunction;
        value           uniform 6e-4;
    }
    frontAndBack
    {
        type            empty;
    }
}

