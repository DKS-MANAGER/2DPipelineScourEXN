// Phase 1: staticFvMesh - pointDisplacement not used by solver.
// Phase 2: dynamicMotionSolverFvMesh reads this field.
//   seabed: driven by exnerEqn (fixedNormalSlip with n=(0 1 0))
//   cylinder: fixedValue zero (rigid pipeline never moves)
//   inlet/outlet/top: fixedValue zero (domain boundaries fixed)
FoamFile
{
    version     2.0;
    format      ascii;
    class       pointVectorField;
    location    "0";
    object      pointDisplacement;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 1 0 0 0 0 0];

internalField   uniform (0 0 0);

boundaryField
{
    inlet
    {
        type            fixedValue;
        value           uniform (0 0 0);
    }
    outlet
    {
        type            fixedValue;
        value           uniform (0 0 0);
    }
    top
    {
        type            fixedValue;
        value           uniform (0 0 0);
    }
    seabed
    {
        type            fixedNormalSlip;
        n               (0 1 0);
        value           uniform (0 0 0);
    }
    cylinder
    {
        type            fixedValue;
        value           uniform (0 0 0);
    }
    frontAndBack
    {
        type            empty;
    }
}

