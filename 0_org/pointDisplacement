// FIX: seabed changed from fixedNormalSlip (n=(0 1 0)) to fixedValue zero.
//      fixedNormalSlip passes the normal (y) component through, allowing
//      the Exner/FA->FV coupling to inject non-zero displacement on step 1,
//      which then corrupts face deltaCoeffs -> SIGFPE on step 2.
// FIX: removed duplicate 'frontAndBack' block.
FoamFile
{
    version     2.0;
    format      ascii;
    class       pointVectorField;
    location    "0";
    object      pointDisplacement;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 1 0 0 0 0 0];

internalField   uniform (0 0 0);

boundaryField
{
    inlet
    {
        type            fixedValue;
        value           uniform (0 0 0);
    }
    outlet
    {
        type            fixedValue;
        value           uniform (0 0 0);
    }
    top
    {
        type            fixedValue;
        value           uniform (0 0 0);
    }
    seabed
    {
        type            fixedValue;
        value           uniform (0 0 0);
    }
    frontAndBack
    {
        type            empty;
    }
}

