FoamFile
{
    version     2.0;
    format      ascii;
    class       pointVectorField;
    location    "0";
    object      pointDisplacement;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 1 0 0 0 0 0];

internalField   uniform (0 0 0);

boundaryField
{
    seabed
    {
        // Overwritten by sedExnerFoam Exner solver at each timestep.
        type            fixedValue;
        value           uniform (0 0 0);
    }

    cylinder
    {
        // Pinned -- cylinder never moves.
        type            fixedValue;
        value           uniform (0 0 0);
    }

    inlet
    {
        // Inlet face does not move.
        type            fixedValue;
        value           uniform (0 0 0);
    }

    outlet
    {
        // Outlet face does not move.
        type            fixedValue;
        value           uniform (0 0 0);
    }

    top
    {
        // Rigid lid -- no displacement.
        type            fixedValue;
        value           uniform (0 0 0);
    }

    frontAndBack
    {
        type            empty;
    }
}

