FoamFile
{
    version     2.0;
    format      ascii;
    class       pointVectorField;
    location    "0_org";
    object      pointDisplacement;
}
// Point displacement field for displacementLaplacian moving mesh solver.
// 'bottom' patch: driven by Exner equation (bed evolution BC).
// All other patches: zero displacement (fixed).
// 'cylinder': zero displacement (rigid body - pipeline does not move).

dimensions      [0 1 0 0 0 0 0];

internalField   uniform (0 0 0);

boundaryField
{
    inlet
    {
        type            fixedValue;
        value           uniform (0 0 0);
    }
    outlet
    {
        type            fixedValue;
        value           uniform (0 0 0);
    }
    surface
    {
        type            fixedValue;
        value           uniform (0 0 0);
    }
    bottom
    {
        // Exner morphodynamic BC:
        // dz/dt = -morphFac/(1-n) * div(qs)
        // Applied as fixedValue updated each timestep by sedExnerFoam.
        // Initial value: zero (flat bed at t=0).
        type            fixedValue;
        value           uniform (0 0 0);
    }
    lateralfront { type empty; }
    lateralback  { type empty; }
    cylinder
    {
        // Rigid pipeline - no displacement
        type            fixedValue;
        value           uniform (0 0 0);
    }
}

