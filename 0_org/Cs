// FIX: removed non-existent 'cylinder' patch block.
// FIX: removed duplicate 'frontAndBack' block.
// FIX: inlet changed to fixedValue 1e-4 (near-bed equilibrium reference
//      concentration). With zeroGradient everywhere Cs=0 is trivially
//      satisfied and no transport occurs - the equation produces Initial
//      residual=0, No Iterations=0 every step.
FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0";
    object      Cs;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 0 0 0 0 0 0];

internalField   uniform 0;

boundaryField
{
    inlet
    {
        type            fixedValue;
        value           uniform 1e-4;
    }
    outlet
    {
        type            zeroGradient;
    }
    top
    {
        type            symmetryPlane;
    }
    seabed
    {
        type            zeroGradient;
    }
    frontAndBack
    {
        type            empty;
    }
}

