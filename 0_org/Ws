// surface: symmetryPlane (must match mesh boundary type).
FoamFile
{
    version     2.0;
    format      ascii;
    class       volVectorField;
    location    "0";
    object      Ws;
    cylinder
    {
        type            zeroGradient;
    }
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 1 -1 0 0 0 0];

internalField   uniform (0 0 0);

boundaryField
{
    inlet
    {
        type            zeroGradient;
    }
    outlet
    {
        type            zeroGradient;
    }
    surface
    {
        type            symmetryPlane;
    }
    bottom
    {
        type            zeroGradient;
    }
    lateralfront
    {
        type            empty;
    }
    lateralback
    {
        type            empty;
    }
    cylinder
    {
        type            zeroGradient;
    }
}

