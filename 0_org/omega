FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0";
    object      omega;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
// omega = k^0.5 / (Cmu^0.25 * l), l=0.01m (1% of pipe D=0.05m)
// omega ~ 60 * nu / (beta1 * y^2) near wall (omegaWallFunction handles this)

dimensions      [0 0 -1 0 0 0 0];

internalField   uniform 10;

boundaryField
{
    inlet
    {
        type            zeroGradient;
        value           uniform 10;
    }
    outlet
    {
        type            zeroGradient;
    }
    top
    {
        type            symmetryPlane;
    }
    seabed
    {
        type            zeroGradient;
        value           uniform 10;
    }
    cylinder
    {
        type            omegaWallFunction;
        value           uniform 10;
    }
    frontAndBack
    {
        type            empty;
    }
    frontAndBack
    {
        type            empty;
    }
}

