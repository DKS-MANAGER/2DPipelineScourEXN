FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0";
    object      omega;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 0 -1 0 0 0 0];

internalField   uniform 15;

boundaryField
{
    inlet
    {
        type            fixedValue;
        value           uniform 15;
    }
    outlet
    {
        type            zeroGradient;
    }
    top
    {
        type            symmetryPlane;
    }
    seabed
    {
        type            omegaWallFunction;
        value           uniform 15;
    }
    cylinder
    {
        type            omegaWallFunction;
        value           uniform 15;
    }
    frontAndBack
    {
        type            empty;
    }
}

