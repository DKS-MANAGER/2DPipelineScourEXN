FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0_org";
    object      omega;
}
// EXTRACTED from DKS-MANAGER/2DPipelineScour/0_org/omega.b
// omega_inlet = ustar^2 / (Cmu^0.5 * k * y)
// At y~0.001m (first cell): omega ~ 0.04318^2 / (0.3 * 0.41 * 0.001) = 15.13
// Using omega_wall = ustar / (Cmu^0.25 * kappa * y_P)
// inlet value ~15 s-1 (consistent with baseline)

dimensions      [0 0 -1 0 0 0 0];

internalField   uniform 15.0;

boundaryField
{
    inlet
    {
        type            fixedValue;
        value           uniform 15.0;
    }
    outlet
    {
        type            zeroGradient;
    }
    surface
    {
        type            zeroGradient;
    }
    bottom
    {
        type            omegaWallFunction;
        value           uniform 15.0;
    }
    lateralfront { type empty; }
    lateralback  { type empty; }
    cylinder
    {
        type            omegaWallFunction;
        value           uniform 15.0;
    }
}

