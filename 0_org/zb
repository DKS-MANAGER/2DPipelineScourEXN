FoamFile
{
    version     2.0;
    format      ascii;
    class       areaScalarField;
    location    "0";
    object      zb;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
// zb: bed elevation [m], initially flat at y = -0.025 m (top of sub-bed block)

dimensions      [0 1 0 0 0 0 0];

internalField   uniform -0.025;

boundaryField
{
    inletFa
    {
        type            zeroGradient;
    }
    outletFa
    {
        type            zeroGradient;
    }
    lateralfrontFa
    {
        type            empty;
    }
    lateralbackFa
    {
        type            empty;
    }
}

