// zb: bed elevation relative to datum [m].
// internalField set to 0 (flat bed at datum). Was -0.025 which drove
// spurious mesh motion on step 1 before any sediment transport occurred.
// The FA solver will evolve zb from this flat initial state.
FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0";
    object      zb;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 1 0 0 0 0 0];

internalField   uniform 0;

boundaryField
{
    inletFa
    {
        type            zeroGradient;
    }
    outletFa
    {
        type            zeroGradient;
    }
    frontAndBackFa
    {
        type            empty;
    }
}

