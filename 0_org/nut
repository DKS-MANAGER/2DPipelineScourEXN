// nut internalField set consistent with k/omega = 1e-3/15 = 6.7e-5
// top: symmetryPlane (must match mesh boundary type).
FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0";
    object      nut;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -1 0 0 0 0];

internalField   uniform 6.7e-5;

boundaryField
{
    inlet
    {
        type            calculated;
        value           uniform 6.7e-5;
    }
    outlet
    {
        type            calculated;
        value           uniform 6.7e-5;
    }
    top
    {
        type            symmetryPlane;
    }
    seabed
    {
        type            nutUSpaldingWallFunction;
        value           uniform 0;
    }
    frontAndBack
    {
        type            empty;
    }
}

