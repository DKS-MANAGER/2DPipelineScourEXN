// FIXES (Renaud et al. 2026, Geosci. Model Dev.):
// 1. top: reverted to symmetryPlane (mesh boundary type = symmetryPlane,
//    field BC must match exactly or OpenFOAM fatal IO error).
// 2. seabed: noSlip (wall functions require zero wall velocity).
// 3. inlet: fixedValue (0.4 0 0) - prevents backflow-driven negative k
//    when pressure correction builds from step 2 onwards.
// 4. Removed duplicate frontAndBack block.
FoamFile
{
    version     2.0;
    format      ascii;
    class       volVectorField;
    location    "0";
    object      U;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 1 -1 0 0 0 0];

internalField   uniform (0.4 0 0);

boundaryField
{
    inlet
    {
        type            fixedValue;
        value           uniform (0.4 0 0);
    }
    outlet
    {
        type            zeroGradient;
    }
    top
    {
        type            symmetryPlane;
    }
    seabed
    {
        type            noSlip;
    }
    frontAndBack
    {
        type            empty;
    }
}

