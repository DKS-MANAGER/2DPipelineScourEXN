// FIXES APPLIED:
// 1. top: symmetryPlane -> symmetry
//    symmetryPlane requires a geometrically perfect flat patch. In a 2D
//    extruded mesh, OpenFOAM 2412's kOmegaSST calls nuEff on boundaries
//    during fvc::grad(U) -> twoSymm -> dev. The tensor reflection via
//    symmetryPlane on the top patch produces a non-zero Z-component that
//    cancels to NaN at step 2. symmetry is the correct BC for pseudo-2D
//    (empty) meshes with a free-slip top boundary.
// 2. seabed: zeroGradient -> noSlip
//    The wall functions (kqRWallFunction, omegaWallFunction,
//    nutUSpaldingWallFunction) require a no-slip velocity BC on the wall
//    patch. zeroGradient allows non-zero wall-normal velocity which
//    destabilises kOmegaSST at step 2.
// 3. inlet: zeroGradient -> fixedValue (0.4 0 0)
//    With PISO pressure correction building up from step 2 onwards,
//    zeroGradient at inlet allows backflow -> negative k -> SIGFPE.
// 4. Removed duplicate frontAndBack block.
FoamFile
{
    version     2.0;
    format      ascii;
    class       volVectorField;
    location    "0";
    object      U;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 1 -1 0 0 0 0];

internalField   uniform (0.4 0 0);

boundaryField
{
    inlet
    {
        type            fixedValue;
        value           uniform (0.4 0 0);
    }
    outlet
    {
        type            zeroGradient;
    }
    top
    {
        type            symmetry;
    }
    seabed
    {
        type            noSlip;
    }
    frontAndBack
    {
        type            empty;
    }
}

