constant/polyMesh/

# Generated finite-area mesh (created by makeFaMesh)
constant/faMesh/

# ParaView / Ensight postprocessing
*.foam
*.case
postProcessing/
VTK/

# OS noise
.DS_Store
Thumbs.db

# Editor noise
*.swp
*.swo
*~
.vscode/
