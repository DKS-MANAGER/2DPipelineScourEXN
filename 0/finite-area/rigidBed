FoamFile
{
    version     2.0;
    format      ascii;
    class       areaVectorField;
    location    "0/finite-area";
    object      rigidBed;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
//
// rigidBed: areaVectorField on the faMesh.
// Zero everywhere = no rigid body displacement imposed on the bed.
// The Exner equation drives all bed motion via zb.

dimensions      [0 1 0 0 0 0 0];

internalField   uniform (0 0 0);

boundaryField
{
    inletFa
    {
        type            fixedValue;
        value           uniform (0 0 0);
    }

    outletFa
    {
        type            zeroGradient;
    }

    frontAndBackFa
    {
        type            empty;
    }
}

