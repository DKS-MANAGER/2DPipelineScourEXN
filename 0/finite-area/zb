FoamFile
{
    version     2.0;
    format      ascii;
    class       areaScalarField;
    location    "0/finite-area";
    object      zb;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
//
// Bed elevation [m] from fixed datum.
// seabed patch sits at y = -0.025 m.
// faMesh edge patches (from constant/finite-area/faMesh/faBoundary):
//   inletFa        -> ngbPolyPatch = inlet
//   outletFa       -> ngbPolyPatch = outlet
//   frontAndBackFa -> ngbPolyPatch = frontAndBack (empty)

dimensions      [0 1 0 0 0 0 0];

internalField   uniform -0.025;

boundaryField
{
    inletFa
    {
        type            fixedValue;
        value           uniform -0.025;
    }

    outletFa
    {
        type            zeroGradient;
    }

    frontAndBackFa
    {
        type            empty;
    }
}

