FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0";
    object      omega;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 0 -1 0 0 0 0];

internalField   uniform 0.5;

boundaryField
{
    inlet
    {
        type            codedFixedValue;
        value           uniform 0.5;
        name            inletOmega;

        codeInclude
        #{
            #include "fvCFD.H"
        #};
        codeOptions
        #{
            -I$(LIB_SRC)/finiteVolume/lnInclude \
            -I$(LIB_SRC)/meshTools/lnInclude
        #};
        codeLibs
        #{
            -lfiniteVolume \
            -lmeshTools
        #};
        code
        #{
            const fvPatch& boundaryPatch = patch();
            const vectorField& Cf = boundaryPatch.Cf();
            scalarField& field = *this;
            forAll(Cf, faceI)
            {
                scalar y    = Cf[faceI].y();
                scalar ustar = 0.04318;
                scalar kappa = 0.41;
                scalar z0   = 3.0e-5;
                if (y > z0)
                    field[faceI] = ustar / (kappa * y);
                else
                    field[faceI] = ustar / (kappa * z0);
            }
        #};
    }

    outlet
    {
        type            zeroGradient;
    }

    surface
    {
        type            symmetryPlane;
    }

    bottom
    {
        type            omegaWallFunction;
        value           uniform 0.5;
    }

    lateralfront
    {
        type            empty;
    }

    lateralback
    {
        type            empty;
    }

    cylinder
    {
        type            omegaWallFunction;
        value           uniform 0.5;
    }
}

