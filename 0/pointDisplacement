FoamFile
{
    version     2.0;
    format      ascii;
    class       pointVectorField;
    location    "0";
    object      pointDisplacement;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
// Required by dynamicMesh / movingMesh if enabled.
// All patches fixed (zero displacement) for rigid mesh case.

dimensions      [0 1 0 0 0 0 0];

internalField   uniform (0 0 0);

boundaryField
{
    inlet
    {
        type            fixedValue;
        value           uniform (0 0 0);
    }

    outlet
    {
        type            fixedValue;
        value           uniform (0 0 0);
    }

    surface
    {
        type            fixedValue;
        value           uniform (0 0 0);
    }

    bottom
    {
        type            fixedValue;
        value           uniform (0 0 0);
    }

    lateralfront
    {
        type            empty;
    }

    lateralback
    {
        type            empty;
    }

    cylinder
    {
        type            fixedValue;
        value           uniform (0 0 0);
    }
}

