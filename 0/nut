FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0";
    object      nut;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -1 0 0 0 0];

internalField   uniform 0;

boundaryField
{
    inlet
    {
        type            calculated;
        value           uniform 0;
    }

    outlet
    {
        type            calculated;
        value           uniform 0;
    }

    surface
    {
        type            calculated;
        value           uniform 0;
    }

    bottom
    {
        type            nutURoughWallFunction;
        roughnessHeight     3.0e-5;
        roughnessConstant   0.5;
        roughnessFactor     1.0;
        value           uniform 0;
    }

    lateralfront
    {
        type            empty;
    }

    lateralback
    {
        type            empty;
    }

    cylinder
    {
        type            nutkWallFunction;
        value           uniform 0;
    }
}

// ************************************************************************* //
