FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0";
    object      Cs;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
// Suspended sediment concentration (volume fraction)
// Initial: zero everywhere (no suspended load at t=0)

dimensions      [0 0 0 0 0 0 0];

internalField   uniform 0;

boundaryField
{
    inlet
    {
        type            fixedValue;
        value           uniform 0;
    }

    outlet
    {
        type            zeroGradient;
    }

    surface
    {
        type            zeroGradient;
    }

    bottom
    {
        type            zeroGradient;
    }

    lateralfront
    {
        type            empty;
    }

    lateralback
    {
        type            empty;
    }

    cylinder
    {
        type            zeroGradient;
    }
}

