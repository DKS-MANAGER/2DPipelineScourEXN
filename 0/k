FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0";
    object      k;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
// k = 1.5*(I*U)^2, I=0.05 (5% turbulence intensity), U=0.4 m/s
// k = 1.5*(0.05*0.4)^2 = 6e-4 m2/s2

dimensions      [0 2 -2 0 0 0 0];

internalField   uniform 6e-4;

boundaryField
{
    inlet
    {
        type            zeroGradient;
        value           uniform 6e-4;
    }
    outlet
    {
        type            zeroGradient;
    }
    top
    {
        type            symmetryPlane;
    }
    seabed
    {
        type            zeroGradient;
        value           uniform 6e-4;
    }
    frontAndBack
    {
        type            empty;
    }
    frontAndBack
    {
        type            empty;
    }
}

