FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system/finite-area";
    object      faSolution;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
//
// faSolution — linear solver settings for finite-area fields
//
// The primary FA field is zb (bed elevation, solved by Exner equation).
// PCG with DIC preconditioner is standard for symmetric positive-definite
// Laplacian-type systems on the faMesh.

solvers
{
    zb
    {
        solver          PCG;
        preconditioner  DIC;
        tolerance       1e-8;
        relTol          0.01;
    }

    // Bedload flux potential (if used by sedExnerFoam)
    hSed
    {
        solver          PCG;
        preconditioner  DIC;
        tolerance       1e-8;
        relTol          0.01;
    }
}

