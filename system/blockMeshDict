FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      blockMeshDict;
}

// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
//
// COORDINATE SYSTEM: IDENTICAL TO SEDFOAM 2DPipelineScour.
//
// Key y-levels (unchanged from SedFoam blockMeshDict):
//   y =  0.205  free surface (top patch)
//   y =  0.080  intermediate grading layer
//   y = -0.025  bed surface  <-- seabed patch lives here
//
// What was REMOVED:
//   Block 2 of SedFoam (y=-0.1 to y=-0.025, the sub-bed sediment layer).
//   That block existed solely to hold the initial alpha.a=0.6 packed-bed
//   region. sedExnerFoam has no sediment phase volume -- the bed is a
//   deforming boundary patch, not a mesh region.
//
// Cylinder STL (constant/triSurface/Cylinder.stl) is UNTOUCHED.
// Its position relative to y=-0.025 (the bed) is preserved exactly,
// so the gap ratio e/D is identical between the two solvers.
//
// Patch name changes (required by sedExnerFoam and faMesh):
//   bottom              -> seabed       (faMesh built on this exact name)
//   surface             -> top          (symmetryPlane type kept)
//   lateralfront        -> frontAndBack (merged into one empty patch)
//   lateralback         -> frontAndBack (merged into one empty patch)

scale   1.0;

vertices
(
    // --- z = 0.001 face (front) ---
    (-0.75   0.205   0.001)  // 0   [was vertex 0 in SedFoam]
    ( 1.0    0.205   0.001)  // 1   [was vertex 1]
    (-0.75   0.080   0.001)  // 2   [was vertex 2]
    ( 1.0    0.080   0.001)  // 3   [was vertex 3]
    (-0.75  -0.025   0.001)  // 4   [was vertex 4]  <-- BED LEVEL y=-0.025
    ( 1.0   -0.025   0.001)  // 5   [was vertex 5]

    // --- z = 0.0 face (back) ---
    (-0.75   0.205   0.0)    // 6   [was vertex 8]
    ( 1.0    0.205   0.0)    // 7   [was vertex 9]
    (-0.75   0.080   0.0)    // 8   [was vertex 10]
    ( 1.0    0.080   0.0)    // 9   [was vertex 11]
    (-0.75  -0.025   0.0)    // 10  [was vertex 12]
    ( 1.0   -0.025   0.0)    // 11  [was vertex 13]

    // vertices 14,15 (sub-bed base at y=-0.1) DELETED -- block 2 removed
);

blocks
(
    // Block 0: upper fluid region (y=0.080 to y=0.205)
    // PRESERVED from SedFoam block 0 -- cell count and grading unchanged.
    // Grading 3.9754 stretches cells upward away from the cylinder,
    // keeping fine resolution near the cylinder top.
    hex (8 9 7 6 2 3 1 0)   (578 20 1)  simpleGrading (1 3.9754 1)

    // Block 1: lower fluid region (y=-0.025 to y=0.080)
    // PRESERVED from SedFoam block 1 -- cell count and grading unchanged.
    // Uniform grading in y gives even cell spacing near the bed.
    // snappyHexMesh will cut the cylinder hole through both blocks.
    hex (10 11 9 8 4 5 3 2)  (578 35 1)  simpleGrading (1 1 1)

    // Block 2 of SedFoam DELETED:
    // hex (14 15 13 12 6 7 5 4) (578 25 1) simpleGrading (1 1 1)
    // This was the sub-bed sediment layer. Removing it shrinks the
    // mesh from 3 blocks to 2. The seabed patch now sits on the
    // bottom faces of Block 1 at y=-0.025.
);

edges
(
    // No arc edges in background mesh.
    // Cylinder surface arcs are generated by snappyHexMesh from
    // constant/triSurface/Cylinder.stl.
);

patches
(
    patch inlet
    (
        (4 10 8 2)   // lower block (Block 1) inlet face
        (2 8  6 0)   // upper block (Block 0) inlet face
    )

    patch outlet
    (
        (7 1 3 9)    // upper block (Block 0) outlet face
        (9 3 5 11)   // lower block (Block 1) outlet face
    )

    // RENAMED from "surface". Type symmetryPlane preserved.
    // Rigid-lid free surface treatment -- same as SedFoam.
    symmetryPlane top
    (
        (6 7 1 0)    // top face of Block 0
    )

    // RENAMED from "bottom".
    // CRITICAL NAME: faMesh (makeFaMesh), pointDisplacement BC,
    // omegaWallFunction, movingWallVelocity, and the Exner solver
    // all look for a patch named exactly "seabed".
    // If this name is wrong, makeFaMesh will fail with:
    //   "cannot find patch seabed in polyMesh/boundary"
    wall seabed
    (
        (4 5 11 10)  // bottom face of Block 1 at y=-0.025
    )

    // MERGED: SedFoam had "lateralfront" (z=0.001) and "lateralback" (z=0.0)
    // as two separate empty patches. Merged into one for cleaner setup.
    // Both are still type empty -- 2D extrusion, no flux in z.
    empty frontAndBack
    (
        // front faces (z=0.001 plane)
        (4 5 3 2)    // Block 1 front
        (2 3 1 0)    // Block 0 front
        // back faces (z=0.0 plane)
        (10 11 9 8)  // Block 1 back
        (8  9  7 6)  // Block 0 back
    )
);

mergePatchPairs
(
);

