FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      extrudeMeshDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
//
// extrudeMeshDict
//
// PURPOSE: enforce the 2D empty-patch condition on lateralfront.
//
// The blockMesh already creates a single-cell slab (z: 0 to 0.001).
// snappyHexMesh preserves this z-thickness but writes lateralfront
// as type 'wall' (it doesn't know it's a 2D symmetry plane).
// extrudeMesh with constructFrom mesh re-processes the existing mesh
// and correctly sets lateralfront as the 2D empty patch pair.
//
// PATCH NAME: must match constant/polyMesh/boundary exactly.
// Verify with: grep -B1 'empty' constant/polyMesh/boundary

constructFrom   mesh;

sourceCase      ".";

// The front face patch (z=0) -- extrudeMesh will pair it with
// the back face (z=0.001) and set both to type empty.
sourcePatches   (lateralfront);

exposedPatchName lateralfront;

flipNormals     false;

extrudeModel    linearNormal;

nLayers         1;

expansionRatio  1.0;

linearNormalCoeffs
{
    thickness   0.001;
}

mergeFaces      false;

// ************************************************************************* //
