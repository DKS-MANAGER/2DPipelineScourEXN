FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      snappyHexMeshDict;
}

// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
//
// THREE FIXES applied vs original SedFoam version:
//
// FIX A — locationInMesh:
//   OLD: (-0.1  0.2  1e-5)  -- y=0.2 was inside the deleted sub-bed block
//   NEW: (-0.1  0.1  1e-5)  -- safely in fluid column, upstream of cylinder
//
// FIX B — Refinement box y-bounds:
//   All boxes with min.y < -0.025 have been clipped to min.y = -0.025.
//   The sub-bed mesh region (y < -0.025) no longer exists after blockMesh.
//   snappy silently refines zero cells if the box is outside the mesh --
//   no error, no warning, just lost near-bed resolution.
//
// FIX C — seabed boundary layers:
//   Added seabed to addLayersControls.
//   sedExnerFoam extracts tau_b from the wall-adjacent cell via
//   omegaWallFunction. Without near-bed layers the first cell is
//   too coarse (y+ >> 300) and tau_b -- which drives the entire
//   Exner morphodynamic update -- is severely underestimated.
//   8 layers, firstLayerThickness=5e-5 m gives y+~30 at u*=0.043 m/s.
//   Fewer layers than cylinder (20) because the bed deforms during
//   scour -- excessive layers collapse in the scour pit.

castellatedMesh true;
snap            true;
addLayers       true;

geometry
{
    Cylinder.stl
    {
        type triSurfaceMesh;
        name cylinder;
    }

    // FIX B applied to all boxes below.
    // All min.y values clipped to -0.025 (bed level).
    // max.y and all x, z values PRESERVED from original.

    surface1
    {
        type searchableBox;
        min (-0.03  -0.025  0.0);
        max ( 0.1    0.05   0.001);
    }

    surface2
    {
        // ORIGINAL: min (-0.75 -0.03 0.0) -- min.y was in deleted region
        // FIXED:    min.y clipped to -0.025
        type searchableBox;
        min (-0.75  -0.025  0.0);
        max ( 1.6    0.025  0.001);
    }

    surface3
    {
        // ORIGINAL: min (-0.1 -0.045 0.0) -- min.y was in deleted region
        // FIXED:    min.y clipped to -0.025
        type searchableBox;
        min (-0.1   -0.025  0.0);
        max ( 0.2    0.025  0.001);
    }

    surface4
    {
        // ORIGINAL: min (-0.07 -0.06 0.0) -- min.y was in deleted region
        // FIXED:    min.y clipped to -0.025
        type searchableBox;
        min (-0.07  -0.025  0.0);
        max ( 0.12   0.025  0.001);
    }

    surface5
    {
        // ORIGINAL: min (-0.06 -0.075 0.0) -- min.y was in deleted region
        // FIXED:    min.y clipped to -0.025
        type searchableBox;
        min (-0.06  -0.025  0.0);
        max ( 0.07   0.025  0.001);
    }

    surface6
    {
        // min.y was 0.0 in original -- already above bed, no fix needed.
        // Preserved exactly.
        type searchableBox;
        min ( 0.0   -0.025  0.0);
        max ( 0.35   0.01   0.001);
    }

    surface7
    {
        // ORIGINAL: min (-0.15 -0.03 0.0) -- min.y was in deleted region
        // FIXED:    min.y clipped to -0.025
        type searchableBox;
        min (-0.15  -0.025  0.0);
        max ( 0.0    0.05   0.001);
    }

    surface8
    {
        // ORIGINAL: min (-0.75 -0.045 0.0) -- min.y was in deleted region
        // FIXED:    min.y clipped to -0.025
        type searchableBox;
        min (-0.75  -0.025  0.0);
        max (-0.5    0.025  0.001);
    }

    surface9
    {
        // ORIGINAL: min (0.2 -0.025 0.0) -- min.y was exactly at bed, fine.
        // Preserved exactly.
        type searchableBox;
        min ( 0.2   -0.025  0.0);
        max ( 0.35   0.005  0.001);
    }
}

castellatedMeshControls
{
    maxLocalCells       1000000;
    maxGlobalCells      4000000;
    minRefinementCells  0;
    maxLoadUnbalance    0.10;
    nCellsBetweenLevels 3;

    features ();

    refinementSurfaces
    {
        cylinder
        {
            level (1 1);
        }
    }

    resolveFeatureAngle 30;

    refinementRegions
    {
        surface1 { mode inside; levels ((1E15 2)); }
        surface2 { mode inside; levels ((1E15 2)); }
        surface3 { mode inside; levels ((1E15 2)); }
        surface4 { mode inside; levels ((1E15 2)); }
        surface5 { mode inside; levels ((1E15 2)); }
        surface6 { mode inside; levels ((1E15 2)); }
        surface7 { mode inside; levels ((1E15 1)); }
        surface8 { mode inside; levels ((1E15 2)); }
        surface9 { mode inside; levels ((1E15 2)); }
    }

    // FIX A: locationInMesh corrected.
    // OLD: (-0.1  0.2  0.00001) -- y=0.2 is above the domain top (y=0.205)
    //      and was inside the deleted sub-bed block in the original SedFoam mesh.
    // NEW: (-0.1  0.1  0.00001) -- midway up the fluid column (y=0.1),
    //      upstream of cylinder (x=-0.1), safely inside the retained mesh.
    locationInMesh (-0.1  0.1  0.00001);

    allowFreeStandingZoneFaces true;
}

snapControls
{
    nSmoothPatch  3;
    tolerance     2.0;
    nSolveIter    30;
    nRelaxIter    5;
}

addLayersControls
{
    relativeSizes false;

    layers
    {
        // PRESERVED: cylinder layers unchanged from original.
        // 20 layers, smooth expansion, fine first-cell for y+~1 resolution.
        "(cylinder).*"
        {
            nSurfaceLayers      20;
        }

        // FIX C: seabed layers ADDED.
        // sedExnerFoam reads wall shear stress tau_b from the cell adjacent
        // to the seabed patch via omegaWallFunction. This drives the Shields
        // parameter theta = tau_b / ((rhoS-rhoF)*g*d50) in the Exner equation.
        // Without near-bed layers the first cell sits at y+ >> 300, causing
        // severe underestimation of tau_b and near-zero predicted scour.
        //
        // Target: y+ ~ 30 at u* = 0.043 m/s (estimated peak friction velocity
        // under the cylinder for U0=0.35 m/s, d50=0.36mm).
        // y1 = y+ * nu / u* = 30 * 1e-6 / 0.043 = 7e-4 m
        // Using firstLayerThickness = 5e-5 m (conservative, allows for higher u*).
        //
        // 8 layers (not 20): bed deforms during scour. Excessive layers
        // in the scour pit compress and invert -- 8 gives adequate resolution
        // while remaining stable through ~3D of scour depth.
        seabed
        {
            nSurfaceLayers      8;
            expansionRatio      1.2;
            firstLayerThickness 5e-5;
            minThickness        1e-8;
        }
    }

    expansionRatio          1.19;
    firstLayerThickness     0.00002;
    minThickness            0.00000001;

    nGrow                   0;
    featureAngle            60;
    nRelaxIter              5;
    nSmoothSurfaceNormals   1;
    nSmoothNormals          3;
    nSmoothThickness        10;
    maxFaceThicknessRatio   0.5;
    maxThicknessToMedialRatio 0.3;
    minMedianAxisAngle      90;
    minMedialAxisAngle      90;
    nBufferCellsNoExtrude   0;
    nLayerIter              50;
}

meshQualityControls
{
    maxNonOrtho             65;
    maxBoundarySkewness     20;
    maxInternalSkewness     4;
    maxConcave              80;
    minVol                  1e-13;
    minTetQuality           1e-30;
    minArea                 -1;
    minTwist                0.05;
    minDeterminant          0.001;
    minFaceWeight           0.05;
    minVolRatio             0.01;
    minTriangleTwist        -1;
    nSmoothScale            4;
    errorReduction          0.75;
}

debug           0;
mergeTolerance  1e-6;

