FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      snappyHexMeshDict;
}

// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
//
// FIXES applied vs previous version:
//
// FIX A - locationInMesh: (-0.1 0.1 0.00001) -- upstream of cylinder, mid-column
// FIX B - Refinement box y-bounds: all min.y clipped to -0.025 (bed level)
// FIX C - seabed boundary layers added
// FIX D - features entry added: Cylinder.eMesh (run surfaceFeatureExtract first)
//         Without feature edges snappy cannot snap to cylinder in 1-cell-thick
//         2D mesh and silently produces no cylinder patch.
// FIX E - cylinder refinementSurfaces level raised from (1 1) to (3 4)
//         50mm cylinder, ~3mm base cells: level 1 = ~2 cells across = too coarse
//         level 3 = ~16 cells across = sufficient for castellated snapping

castellatedMesh true;
snap            true;
addLayers       true;

geometry
{
    Cylinder.stl
    {
        type triSurfaceMesh;
        name cylinder;
    }

    surface1
    {
        type searchableBox;
        min (-0.03  -0.025  0.0);
        max ( 0.1    0.05   0.001);
    }

    surface2
    {
        type searchableBox;
        min (-0.75  -0.025  0.0);
        max ( 1.6    0.025  0.001);
    }

    surface3
    {
        type searchableBox;
        min (-0.1   -0.025  0.0);
        max ( 0.2    0.025  0.001);
    }

    surface4
    {
        type searchableBox;
        min (-0.07  -0.025  0.0);
        max ( 0.12   0.025  0.001);
    }

    surface5
    {
        type searchableBox;
        min (-0.06  -0.025  0.0);
        max ( 0.07   0.025  0.001);
    }

    surface6
    {
        type searchableBox;
        min ( 0.0   -0.025  0.0);
        max ( 0.35   0.01   0.001);
    }

    surface7
    {
        type searchableBox;
        min (-0.15  -0.025  0.0);
        max ( 0.0    0.05   0.001);
    }

    surface8
    {
        type searchableBox;
        min (-0.75  -0.025  0.0);
        max (-0.5    0.025  0.001);
    }

    surface9
    {
        type searchableBox;
        min ( 0.2   -0.025  0.0);
        max ( 0.35   0.005  0.001);
    }
}

castellatedMeshControls
{
    maxLocalCells       2000000;
    maxGlobalCells      8000000;
    minRefinementCells  0;
    maxLoadUnbalance    0.10;
    nCellsBetweenLevels 3;

    // FIX D: feature edges from surfaceFeatureExtract.
    // Run: surfaceFeatureExtract
    // before snappyHexMesh to generate constant/triSurface/Cylinder.eMesh
    features
    (
        {
            file "Cylinder.eMesh";
            level 4;
        }
    );

    refinementSurfaces
    {
        cylinder
        {
            // FIX E: raised from (1 1) to (3 4).
            // Base cell ~3mm; level 3 = 0.375mm, level 4 = 0.1875mm.
            // Gives ~16-32 cells across 50mm diameter for reliable snapping.
            level (3 4);
        }
    }

    resolveFeatureAngle 30;

    refinementRegions
    {
        cylinder
        {
            // Distance-based grading away from cylinder surface.
            // Ensures smooth transition from fine cylinder cells
            // to coarser background cells.
            mode distance;
            levels ((0.025 4)(0.05 3)(0.1 2));
        }
        surface1 { mode inside; levels ((1E15 2)); }
        surface2 { mode inside; levels ((1E15 2)); }
        surface3 { mode inside; levels ((1E15 2)); }
        surface4 { mode inside; levels ((1E15 2)); }
        surface5 { mode inside; levels ((1E15 2)); }
        surface6 { mode inside; levels ((1E15 2)); }
        surface7 { mode inside; levels ((1E15 1)); }
        surface8 { mode inside; levels ((1E15 2)); }
        surface9 { mode inside; levels ((1E15 2)); }
    }

    locationInMesh (-0.1  0.1  0.00001);

    allowFreeStandingZoneFaces true;
}

snapControls
{
    nSmoothPatch  3;
    tolerance     2.0;
    nSolveIter    50;
    nRelaxIter    5;
}

addLayersControls
{
    relativeSizes false;

    layers
    {
        "(cylinder).*"
        {
            nSurfaceLayers      20;
            expansionRatio      1.3;
            firstLayerThickness 0.00002;
            minThickness        1e-8;
        }

        seabed
        {
            nSurfaceLayers      8;
            expansionRatio      1.2;
            firstLayerThickness 5e-5;
            minThickness        1e-8;
        }
    }

    expansionRatio          1.19;
    firstLayerThickness     0.00002;
    minThickness            0.00000001;

    nGrow                   0;
    featureAngle            60;
    nRelaxIter              5;
    nSmoothSurfaceNormals   1;
    nSmoothNormals          3;
    nSmoothThickness        10;
    maxFaceThicknessRatio   0.5;
    maxThicknessToMedialRatio 0.3;
    minMedianAxisAngle      90;
    minMedialAxisAngle      90;
    nBufferCellsNoExtrude   0;
    nLayerIter              50;
}

meshQualityControls
{
    maxNonOrtho             65;
    maxBoundarySkewness     20;
    maxInternalSkewness     4;
    maxConcave              80;
    minVol                  1e-13;
    minTetQuality           1e-30;
    minArea                 -1;
    minTwist                0.05;
    minDeterminant          0.001;
    minFaceWeight           0.05;
    minVolRatio             0.01;
    minTriangleTwist        -1;
    nSmoothScale            4;
    errorReduction          0.75;
}

debug           0;
mergeTolerance  1e-6;

// ************************************************************************* //
