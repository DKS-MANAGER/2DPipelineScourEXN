// PHASE 2 dynamicMeshDict (bedMotion on, active scour).
// Copy to system/dynamicMeshDict before starting phase 2 run.
//
// inverseDist references 'bottom' (the actual faMesh/bed patch name).
// This diffuses bed deformation upward: cells near bottom deform most,
// upper fluid cells near free surface barely move.
FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      dynamicMeshDict;
}

dynamicFvMesh       dynamicMotionSolverFvMesh;

motionSolverLibs    ("libfvMotionSolvers.so");

motionSolver        displacementLaplacian;

displacementLaplacianCoeffs
{
    diffusivity     inverseDist 1 (bottom);
}

