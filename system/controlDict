FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

application     sedExnerFoam;

startFrom       latestTime;

startTime       0;

stopAt          endTime;

endTime         4;

deltaT          1e-4;

writeControl    adjustableRunTime;

writeInterval   0.5;

purgeWrite      0;

writeFormat     binary;

writePrecision  6;

writeCompression false;

timeFormat      general;

timePrecision   6;

runTimeModifiable on;

adjustTimeStep  yes;

maxCo           0.1;

maxDeltaT       5e-3;

functions
{
    scourDepthProbe
    {
        type            probes;
        libs            (sampling);
        writeControl    timeStep;
        writeInterval   10;
        probeLocations
        (
            // Mid water-column: safe from bed crush for entire run.
            // y=-0.024 (1mm above bed) was getting destroyed by first
            // mesh motion step -> probe warning -> SIGFPE in deltaCoeffs.
            ( 0.0  0.100  0.0005 )
        );
        fields          ( U p k Cs );
    }

    residuals
    {
        type            solverInfo;
        libs            (utilityFunctionObjects);
        fields          (U p k omega Cs);
        writeControl    timeStep;
        writeInterval   1;
    }
}

// ************************************************************************* //
