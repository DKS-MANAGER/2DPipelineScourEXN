// Baseline ran to t=5s physical (sedFoam).
// sedExnerFoam target: 45s physical (full scour development).
// maxCo=0.1, maxDeltaT=0.05s preserved from baseline adjustableRunTime.
// morphFac=10 accelerates bed evolution; writeInterval=0.5s.
FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      controlDict;
}

application         sedExnerFoam;

startFrom           latestTime;
startTime           0;
stopAt              endTime;
endTime             45;

deltaT              1e-3;

writeControl        adjustableRunTime;
writeInterval       0.5;
purgeWrite          0;
writeFormat         binary;
writePrecision      6;
writeCompression    false;
timeFormat          general;
timePrecision       6;
runTimeModifiable   yes;
adjustTimeStep      yes;
maxCo               0.1;
maxDeltaT           0.05;

functions
{
    // Scour depth at x=0 (directly below cylinder centreline)
    scourDepth
    {
        type            surfaceFieldValue;
        libs            ("libfieldFunctionObjects.so");
        writeControl    writeTime;
        log             yes;
        writeFields     no;
        regionType      patch;
        name            bottom;
        operation       min;
        fields          (cellCentres);
    }

    // Forces on cylinder for validation against sedFoam
    cylinderForces
    {
        type            forces;
        libs            ("libforces.so");
        writeControl    timeStep;
        writeInterval   10;
        log             yes;
        patches         (cylinder);
        rho             rhoInf;
        rhoInf          1000;
        CofR            (0 0.0255 0.0005);
    }
}

