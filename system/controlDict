// FIX HISTORY:
// - adjustTimeStep disabled: deltaT jump (0.00075->0.0009) caused ddt
//   coefficient NaN in fvc::ddtCorr -> SIGFPE before first solver on step 2.
// - scourDepth function: patch name was 'bottom' (non-existent); changed to
//   'seabed'. Operation changed to 'min' on 'p' (cellCentres not a valid
//   scalar for min operation on a patch).
// - cylinderForces function: removed entirely - 'cylinder' patch does not
//   exist in this mesh (snappyHexMesh produced inlet/outlet/top/seabed/
//   frontAndBack only). Forces function on missing patch -> FOAM FATAL at t=0.
FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      controlDict;
}

application         sedExnerFoam;

startFrom           latestTime;
startTime           0;
stopAt              endTime;
endTime             45;

deltaT              5e-4;

writeControl        adjustableRunTime;
writeInterval       0.5;
purgeWrite          0;
writeFormat         binary;
writePrecision      6;
writeCompression    false;
timeFormat          general;
timePrecision       6;
runTimeModifiable   yes;
adjustTimeStep      no;

functions
{
    scourDepth
    {
        type            surfaceFieldValue;
        libs            ("libfieldFunctionObjects.so");
        writeControl    writeTime;
        log             yes;
        writeFields     no;
        regionType      patch;
        name            seabed;
        operation       min;
        fields          (p);
    }
}

