// PHASE 1 (spin-up, bedMotion off): staticFvMesh — mesh never moves.
// Root cause of SIGFPE: dynamicMotionSolverFvMesh was active with
// inverseDist referencing patch 'bottom' which does not exist in the mesh
// (actual patch is 'bottom'). Missing patch -> diffusivity = 0 everywhere
// -> singular Laplacian system -> NaN point displacements -> zero-volume
// cells -> nonOrthDeltaCoeffs = 1/0 -> SIGFPE in kOmegaSST::correct().
//
// PHASE 2 (scour, bedMotion on): replace with:
//   dynamicFvMesh       dynamicMotionSolverFvMesh;
//   motionSolverLibs    ("libfvMotionSolvers.so");
//   motionSolver        displacementLaplacian;
//   displacementLaplacianCoeffs { diffusivity inverseDist 1 (bottom); }
FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      dynamicMeshDict;
}

dynamicFvMesh   staticFvMesh;

