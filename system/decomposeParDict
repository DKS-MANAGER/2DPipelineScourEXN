FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      decomposeParDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

numberOfSubdomains  8;

method              scotch;

// CRITICAL for sedExnerFoam:
// singleProcessorFaceSets keeps all seabed patch faces on rank 0
// so the sequential faMesh / Exner solver works in a parallel run.
// v2412 API requires keyword 'sets' (not 'faceSets').
constraints
{
    seabedConstraint
    {
        type        singleProcessorFaceSets;
        sets        (seabed);
        processor   0;
    }
}

