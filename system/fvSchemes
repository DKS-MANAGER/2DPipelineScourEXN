FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      fvSchemes;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

ddtSchemes
{
    default         Euler;
}

gradSchemes
{
    default         Gauss linear;
    grad(k)         cellLimited Gauss linear 1;
    grad(omega)     cellLimited Gauss linear 1;
    grad(U)         cellLimited Gauss linear 1;
}

divSchemes
{
    div((nuEff*dev2(T(grad(U)))))  Gauss linear;

    div(phi,U)          Gauss linearUpwind grad(U);

    div(phi,k)          Gauss linearUpwind grad(k);
    div(phi,omega)      Gauss linearUpwind grad(omega);

    // vanLeer is a TVD scheme: strictly bounded [0,1] by construction.
    // linearUpwind is unbounded and produces Min(Cs) = -3e-320 denormals
    // at t=0 when Cs=0 everywhere, which corrupts the Exner bedload flux.
    div(phi,Cs)         Gauss vanLeer;
    div(phip,Cs)        Gauss vanLeer;
    div(phi,Ws)         Gauss vanLeer;
    div(phip,Ws)        Gauss vanLeer;

    default         none;
}

laplacianSchemes
{
    default         Gauss linear corrected;
}

interpolationSchemes
{
    default         linear;
}

snGradSchemes
{
    default         corrected;
}

fluxRequired
{
    default         no;
    p               ;
}

wallDist
{
    method meshWave;
}

