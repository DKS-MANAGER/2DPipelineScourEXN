FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      sedimentProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

// ── GRAIN PROPERTIES ────────────────────────────────────────────────────────
// All values extracted directly from SedFoam constant/transportProperties
// phasea block. Do not modify without updating transportProperties to match.

d50             3.6e-4;         // [m]  median grain diameter
rhoSediment     2650;           // [kg/m3]  sediment density
rhoFluid        1000;           // [kg/m3]  fluid density
nu              1e-6;           // [m2/s]  kinematic viscosity
porosity        0.365;          // [-]  = 1 - alphaMax(0.635) from ppProperties

// Derived quantities (computed by sedExnerFoam at startup -- verify in log):
// D*  = d50 * ((s-1)*g/nu^2)^(1/3)
//     = 3.6e-4 * ((1.65*9.81)/(1e-6)^2)^(1/3) = 9.1
//
// ws  = 0.022 m/s  (settling velocity, van Rijn 1984, D*=9.1, D*<10 regime)
//   Formula: ws = (nu/d50) * (sqrt(0.25 + (4/3)*D*^3/18) - 0.5)^2
//
// th_c = 0.034  (critical Shields, Soulsby-Whitehouse 1997, D*=9.1)
//   Formula: th_c = 0.30/(1+1.2*D*) + 0.055*(1-exp(-0.020*D*))

// ── BEDLOAD MODEL ────────────────────────────────────────────────────────────
// Using Nielsen (1992) form: q_b* = alpha * sqrt(theta) * (theta - theta_c)
// Coefficients MUST match bedloadProperties to avoid sub-model mismatch.
// bedloadProperties alpha=7.2 is the authoritative source for the solver;
// the NielsenCoeffs block here is retained as documentation only.
bedloadModel    Nielsen;

NielsenCoeffs
{
    // Nielsen (1992) original: alpha=7.2, aExp=0.5, bExp=1
    // (matches bedloadProperties exactly)
    alpha           7.2;
    aExp            0.5;
    bExp            1.0;
}

// ── CRITICAL SHIELDS PARAMETER ──────────────────────────────────────────────
criticalShieldsModel    SoulsbyWhitehouse1997;

// ── SLOPE CORRECTION ────────────────────────────────────────────────────────
slopeCorrection         on;
slopeCorrectionModel    FredsoeDeigaard1992;
angleOfRepose           32;

// ── AVALANCHE MODEL ─────────────────────────────────────────────────────────
avalancheModel          on;
avalancheCoeffs
{
    tanPhiAvalanching   0.6249;
    diffusionCoeff      0.1;
}

// ── SUSPENDED LOAD MODEL ────────────────────────────────────────────────────
suspendedLoad           on;
settlingVelocityModel   vanRijn1984;
SchmidtNumber           1.0;
erosionModel            vanRijn1984;

vanRijn1984ErosionCoeffs
{
    referenceHeight     5.4e-4;
    T_coefficient       0.015;
    T_exponent          1.5;
}

// ── MORPHODYNAMIC ACCELERATION ──────────────────────────────────────────────
morfac                  1.0;    // MUST remain 1.0 for validation comparison

// ── FAMESH EXNER SOLVER SETTINGS ─────────────────────────────────────────────
ExnerCoeffs
{
    theta               1.0;
    maxBedLevelChange   1e-3;
}

// ************************************************************************* //