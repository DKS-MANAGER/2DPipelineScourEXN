FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      dynamicMeshDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dynamicFvMesh   dynamicMotionSolverFvMesh;

motionSolver    displacementPointSmoothing;

displacementPointSmoothingCoeffs
{
    pointSmoother       laplacian;
    nPointSmootherIter  3;

    // FIXED: was inverseDistance (cylinder) but cylinder patch does not
    // exist in this mesh. inverseDistance on a missing patch returns
    // NaN/inf diffusivity -> corrupts deltaCoeffs -> SIGFPE in motion solver.
    // uniform 1 = standard Laplacian smoothing, correct for a 2D domain
    // with a single moving boundary (seabed).
    diffusivity         uniform 1;
}

