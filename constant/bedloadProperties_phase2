// PHASE 2 bedloadProperties — copy over constant/bedloadProperties
// AFTER spin-up (t=2s) completes successfully.
// Usage:
//   cp constant/bedloadProperties_phase2 constant/bedloadProperties
//   # edit system/controlDict: startFrom latestTime, endTime 45
//   sedExnerFoam 2>&1 | tee log.sedExnerFoam_phase2
FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      bedloadProperties;
}

// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

sedimentBed             on;
sedimentBedPatches      (seabed);

// PHASE 2: bed motion ON — Exner drives mesh deformation
bedMotion               on;

// Adams-Bashforth order 1 — requires a valid restart with stored oldTime
// fields. Safe after spin-up provides t=2s as latestTime.
ABorder                 1;

fixedFaPatches          ();

bedloadModel
{
    type                Nielsen;
    alpha               7.2;
    aExp                0.5;
    bExp                1;
    slopeCorrecton      off;
    gamma               0.1;
    avalanche           on;
    Qav                 1e-3;
    alphaFiltBeta       0.1;
    NfiltBeta           1;
    coefShields         1;
}

criticalShieldsModel
{
    type                Soulsby;
    slopeCorrection     on;
}

// morphoAccFactor=10 accelerates bed evolution in Phase 2
morphoAccFactor         10;

filterExner             on;
alphaFiltExner          0.1;
NfiltExner              3;

rigidBed                off;

// ************************************************************************* //
